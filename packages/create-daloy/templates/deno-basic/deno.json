{
  "name": "my-daloy-deno-app",
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --watch src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "typecheck": "deno check src/main.ts",
    "test": "deno test --allow-net --allow-env tests/",
    "contract": "deno test --allow-net --allow-env tests/contract_test.ts",
    "gen:openapi": "deno run --allow-net --allow-env --allow-read --allow-write scripts/dump-openapi.ts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "imports": {
    "@daloyjs/core": "jsr:@daloyjs/daloy@^1.0.0-beta.0",
    "@daloyjs/core/banner": "jsr:@daloyjs/daloy@^1.0.0-beta.0/banner",
    "@daloyjs/core/contract": "jsr:@daloyjs/daloy@^1.0.0-beta.0/contract",
    "@daloyjs/core/deno": "jsr:@daloyjs/daloy@^1.0.0-beta.0/deno",
    "@daloyjs/core/openapi": "jsr:@daloyjs/daloy@^1.0.0-beta.0/openapi",
    "zod": "npm:zod@^4.4.3"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable"]
  },
  "fmt": {
    "lineWidth": 100
  }
}
