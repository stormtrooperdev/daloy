    },
    "./openapi-diff": {
      "types": "./dist/openapi-diff.d.ts",
      "import": "./dist/openapi-diff.js"
    },
    "./asyncapi": {
      "types": "./dist/asyncapi.d.ts",
      "import": "./dist/asyncapi.js"
    },
    "./docs": {
      "types": "./dist/docs.d.ts",
      "import": "./dist/docs.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js"
    },
    "./streaming": {
      "types": "./dist/streaming.d.ts",
