      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency.d.ts",
      "import": "./dist/idempotency.js"
    },
    "./response-cache": {
      "types": "./dist/response-cache.d.ts",
